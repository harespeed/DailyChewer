# =========================
# DailyChewer LLM Settings
# =========================

# Option A: Use MiniMax API
# MiniMax international endpoint is commonly:
# MINIMAX_BASE_URL=https://api.minimax.io/v1
#
# MiniMax China endpoint is commonly:
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
#
# Please use the endpoint and model name from your own MiniMax console.

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# Option B: Use any OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: LLM request timeout tuning, in seconds.
# Connect timeout controls how long to wait for the TCP/TLS connection.
# Read timeout controls how long to wait for the model response body.
DAILYCHEWER_LLM_CONNECT_TIMEOUT=10
DAILYCHEWER_LLM_READ_TIMEOUT=60

# =========================
# Database
# =========================
# If DATABASE_URL is unset, CLI local mode can still use data/index.json.
# Web backend mode requires DATABASE_URL.
DATABASE_URL=postgresql+psycopg://dailychewer:dailychewer_password@postgres:5432/dailychewer

# =========================
# Auth
# =========================
# Change JWT_SECRET_KEY in production.
JWT_SECRET_KEY=change_this_secret_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# First admin user created on startup if enabled.
# Change the default password before using this in production.
DAILYCHEWER_CREATE_DEFAULT_USER=true
DAILYCHEWER_DEFAULT_USERNAME=admin
DAILYCHEWER_DEFAULT_PASSWORD=admin123
DAILYCHEWER_DEFAULT_DISPLAY_NAME=Admin

# =========================
# Docker build mirrors
# =========================
# Default: use China mirrors for faster Docker builds in mainland China.
# Set USE_CHINA_MIRROR=false to use official Debian/PyPI sources.

USE_CHINA_MIRROR=true

# Tsinghua mirrors
APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
PIP_TRUSTED_HOST=mirrors.tuna.tsinghua.edu.cn

# Alternative PyPI mirrors:
# Aliyun:
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.aliyun.com
#
# USTC:
# PIP_INDEX_URL=https://mirrors.ustc.edu.cn/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.ustc.edu.cn
#
# Tencent Cloud:
# PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple/
# PIP_TRUSTED_HOST=mirrors.cloud.tencent.com

# Optional: DailyChewer logging
DAILYCHEWER_LOG_LEVEL=INFO

# Optional: privacy controls
DAILYCHEWER_ENABLE_REDACTION=true

# Optional: frontend local development
VITE_API_BASE_URL=http://localhost:8000
VITE_WALLPAPER_API_URL=https://picsum.photos/v2/list?page=2&limit=100

# =========================
# Frontend npm mirror
# =========================
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
